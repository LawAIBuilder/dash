# API bind (use 0.0.0.0 in Docker / PaaS; default 127.0.0.1 for local dev)
WC_API_HOST=127.0.0.1

# Optional: absolute path to authoritative.sqlite (API + OCR worker must match)
WC_SQLITE_PATH=

# Box JWT (Railway: often BOX_JWT_CONFIG raw JSON; local migration tool may wrap under box_jwt_config in a file)
BOX_JWT_CONFIG_JSON=
BOX_JWT_CONFIG_FILE=
BOX_ENTERPRISE_ID=
BOX_USER_ID=
# Optional metadata / probes; for sync MVP use cases.box_root_folder_id = matter "Client File" folder (not PP org root)
BOX_PP_ROOT_FOLDER_ID=
BOX_INCOMING_MAIL_FOLDER_ID=

# Transitional shared bearer fallback (use only when intentionally staying on shared-key mode)
WC_API_KEY=
VITE_WC_API_KEY=
VITE_WC_ENABLE_API_KEY_FALLBACK=

# Preferred hosted browser auth (server-issued HTTP-only session cookie)
WC_SESSION_SECRET=
WC_SESSION_TTL_HOURS=12
WC_SESSION_COOKIE_SECURE=
WC_BOOTSTRAP_ADMIN_EMAIL=
WC_BOOTSTRAP_ADMIN_PASSWORD=
WC_BOOTSTRAP_ADMIN_NAME=
WC_BOOTSTRAP_ADMIN_RESEED=
WC_AUTH_LOGIN_RATE_LIMIT_MAX=
WC_AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=

# CORS for Vite desktop (comma-separated origins)
WC_CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# PracticePanther production sync (optional; unset = use dev/hydrate only)
PP_API_BASE_URL=https://app.practicepanther.com
PP_CLIENT_ID=
PP_CLIENT_SECRET=
# Railway production callback example:
# PP_REDIRECT_URI=https://wc-legal-prep-production.up.railway.app/api/connectors/practicepanther/callback
PP_REDIRECT_URI=

# OCR worker loop size when running: npm run ocr-worker --workspace @wc/api
OCR_WORKER_MAX_PASSES=100
